{
  "compilerOptions": {
    /* Opções Base - Mantivemos as suas que estavam boas */
    "target": "ES2022",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,

    /* Módulo - Configuração moderna para Node.js */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    /* Saída - As linhas que faltavam e corrigem tudo! */
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}